{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "menubar",
        "title": "Codex Gauge",
        "width": 360,
        "height": 480,
        "minWidth": 360,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "visible": false,
        "acceptFirstMouse": true
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
