{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Gauge",
  "version": "0.0.3",
  "identifier": "com.codexgauge.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Gauge",
        "width": 430,
        "height": 104,
        "minWidth": 430,
        "minHeight": 104,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "center": true,
        "visible": true
      },
      {
        "label": "top",
        "title": "Codex Gauge Status",
        "width": 168,
        "height": 26,
        "minWidth": 168,
        "minHeight": 26,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true
      },
      {
        "label": "detail",
        "title": "Codex Gauge Details",
        "width": 460,
        "height": 640,
        "minWidth": 460,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Codex Gauge Settings",
        "width": 620,
        "height": 520,
        "minWidth": 620,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": [
          "SimpChinese"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ydfk/codex-gauge/releases/latest/download/latest.json"
      ],
      "pubkey": "TODO_REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
