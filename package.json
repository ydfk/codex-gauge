{
  "name": "codex-gauge",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "svelte-check",
    "build": "svelte-check && vite build",
    "check": "pnpm build && pnpm rust:check",
    "release:check": "pnpm typecheck && cd src-tauri && cargo fmt --check",
    "rust:check": "cd src-tauri && cargo fmt --check && cargo check && cargo test",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build",
    "mac:doctor": "bash scripts/macos-dev.sh doctor",
    "mac:dev": "bash scripts/macos-dev.sh dev",
    "mac:test": "bash scripts/macos-dev.sh test",
    "mac:open": "bash scripts/macos-dev.sh open",
    "diagnose:codex": "node scripts/diagnose-codex.mjs",
    "diagnose:credits": "node scripts/diagnose-reset-credits.mjs",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-updater": "^2.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.9.4",
    "svelte": "^5.38.10",
    "svelte-check": "^4.3.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  }
}
